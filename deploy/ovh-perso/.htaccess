# Basic Auth (Apache)
AuthType Basic
AuthName "Klub"
AuthBasicProvider file

# USTAW ABSOLUTNĄ ŚCIEŻKĘ DO PLIKU .htpasswd NA SERWERZE:
# np. /homez.XXX/login/www/.htpasswd
AuthUserFile __ABSOLUTE_PATH_TO_HTPASSWD__

Require valid-user

# Hardening (best-effort; depends on enabled Apache modules)
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redirect HTTP -> HTTPS (works when HTTPS is enabled on the subdomain)
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS (only meaningful when HTTPS is active)
  Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"
</IfModule>

# Nie pozwalaj pobrać pliku haseł przez WWW
<Files ".htpasswd">
  Require all denied
</Files>

# Dla starszych konfiguracji Apache (jeśli powyższe nie działa)
<FilesMatch "^\\.htpasswd$">
  Order allow,deny
  Deny from all
</FilesMatch>
